# worker-prep-vision 설정 예시 — 실제 값은 .env(gitignore)로 복사해 채운다.
# 하드코딩 금지: 모든 배포별 값은 여기(.env) 경유. 접속정보·IP 는 placeholder 로만 기재.

## 서버 바인딩(API 리슨)
APP_HOST=127.0.0.1  # 리슨 호스트 — 배포 시 0.0.0.0 또는 사설 IP
APP_PORT=           # 리슨 포트(필수).

## 미디어 — 원본이 있는 호스트에서 로컬 파일로 접근(ssh 아님)
VOD_ROOT=/mnt/nvme/vod        # 원본·프레임 루트. 원본 = {VOD_ROOT}/{v_id}/{file_name(prep 요청 필드)}
# 프레임 출력 루트(비우면 VOD_ROOT 사용). 산출 = {FRAME_ROOT}/{v_id}/seg{id:05d}/f000.jpg
FRAME_ROOT=

## 장면 분할(scenedetect ContentDetector) — 동적 경계(고정 그리드 아님)
PREP_THRESHOLD=15.0           # 낮을수록 컷 촘촘
PREP_MIN_SEC=1.0              # 세그 최소 길이 — 미만이면 이웃과 병합
PREP_MAX_SEC=30.0             # 세그 최대 길이 — 초과하면 균등분할
PREP_MIN_SCENE_FRAMES=15      # 컷 간 최소 프레임 간격

## 프레임 추출(ffmpeg CPU) — 세그당 프레임 수 = max(1, round(길이 × PREP_FPS))
PREP_FPS=0.2                  # 초당 프레임. 0.2 = 5초당 1장(5초 이내 1장, 그 이상 n장)
PREP_SCALE=none               # 프레임 해상도. 'none'=원본(native). 예 '1024:768'(추후 축소 옵션)
PREP_JPG_QUALITY=2            # ffmpeg -q:v (1~31, 낮을수록 고화질)
PREP_CONCURRENCY=4            # 프레임 추출 ffmpeg 동시 실행 수(CPU)

## DB (MariaDB) — t_video 조회 / t_segment 사전등록
DB_IP=<db-host>
DB_PORT=3306
DB_USER=<db-user>
DB_PW=<db-pw>
DB_NAME=<db-name>
DB_POOL_MAX=8
DB_POOL_RECYCLE=240           # 유휴 커넥션 재활용(초) — NAT 경유 dev 는 짧게

## logging
LOG_LEVEL=INFO
LOG_PATH=
